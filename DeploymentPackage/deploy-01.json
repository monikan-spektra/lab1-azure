{
  "$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "CloudLabsDeploymentID": {
      "type": "string"
    },
    "azureUserName": {
      "type": "string"
    },
    "azurePassword": {
      "type": "securestring"
    },
    "adminUsername": {
      "type": "string",
      "defaultValue": "azureuser",
      "metadata": {
        "description": "Accepted for platform compatibility. VM uses VMUserName instead."
      }
    },
    "adminPassword": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Accepted for platform compatibility. VM uses VMPassword instead."
      }
    },
    "trainerUserName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Accepted for platform compatibility."
      }
    },
    "trainerUserPassword": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Accepted for platform compatibility."
      }
    },
    "ODLID": {
      "type": "string"
    },
    "DeploymentID": {
      "type": "string"
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all deployed resources."
      }
    },
    "vpcCidr": {
      "type": "string",
      "defaultValue": "10.10.0.0/16",
      "metadata": {
        "description": "Address space for the Virtual Network (equivalent to VPC CIDR)."
      }
    },
    "subnetCidr": {
      "type": "string",
      "defaultValue": "10.10.0.0/24",
      "metadata": {
        "description": "Address prefix for the VM subnet."
      }
    },
    "clgClusterSubnetCidr": {
      "type": "string",
      "defaultValue": "10.10.1.0/24",
      "metadata": {
        "description": "Address prefix for the container/cluster subnet."
      }
    },
    "vmSize": {
      "type": "string",
      "defaultValue": "Standard_B2s",
      "metadata": {
        "description": "VM size (equivalent to EC2 t3.micro)."
      }
    },
    "VMUserName": {
      "type": "string",
      "defaultValue": "Labuser",
      "metadata": {
        "description": "Administrator username for the Windows VM."
      }
    },
    "VMPassword": {
      "type": "securestring",
      "metadata": {
        "description": "Administrator password for the Windows VM."
      }
    }
  },
  "variables": {
    "virtualNetworkName": "clgVnet",
    "vmSubnetName": "vmSubnet",
    "clgClusterSubnetName": "clgClusterSubnet",
    "vmNsgName": "vmSecurityGroup",
    "clgNsgName": "clgSg",
    "vmPublicIpName": "labvm-pip",
    "vmNicName": "labvm-nic",
    "vmName": "labvm",
    "vmOsDiskName": "labvm-osdisk",
    "containerGroupName": "clg-containergroup"
  },
  "resources": [

    {
      "comments": "NSG for VM subnet - allows RDP and all TCP (mirrors vmSecurityGroup in CFN)",
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-09-01",
      "name": "[variables('vmNsgName')]",
      "location": "[parameters('location')]",
      "properties": {
        "securityRules": [
          {
            "name": "Allow-RDP-Inbound",
            "properties": {
              "priority": 1000,
              "direction": "Inbound",
              "access": "Allow",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "3389",
              "sourceAddressPrefix": "*",
              "destinationAddressPrefix": "*"
            }
          },
          {
            "name": "Allow-All-TCP-Inbound",
            "properties": {
              "priority": 1100,
              "direction": "Inbound",
              "access": "Allow",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefix": "*",
              "destinationAddressPrefix": "*"
            }
          }
        ]
      }
    },

    {
      "comments": "NSG for cluster subnet - fully open inbound/outbound (mirrors clgSg in CFN)",
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-09-01",
      "name": "[variables('clgNsgName')]",
      "location": "[parameters('location')]",
      "properties": {
        "securityRules": [
          {
            "name": "Allow-All-Inbound",
            "properties": {
              "priority": 100,
              "direction": "Inbound",
              "access": "Allow",
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefix": "*",
              "destinationAddressPrefix": "*"
            }
          },
          {
            "name": "Allow-All-Outbound",
            "properties": {
              "priority": 100,
              "direction": "Outbound",
              "access": "Allow",
              "protocol": "*",
              "sourcePortRange": "*",
              "destinationPortRange": "*",
              "sourceAddressPrefix": "*",
              "destinationAddressPrefix": "*"
            }
          }
        ]
      }
    },

    {
      "comments": "Virtual Network with two subnets (equivalent to clgVpc + vmSubnet + clgClusterSubnet)",
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-09-01",
      "name": "[variables('virtualNetworkName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkSecurityGroups', variables('vmNsgName'))]",
        "[resourceId('Microsoft.Network/networkSecurityGroups', variables('clgNsgName'))]"
      ],
      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "[parameters('vpcCidr')]"
          ]
        },
        "subnets": [
          {
            "name": "[variables('vmSubnetName')]",
            "properties": {
              "addressPrefix": "[parameters('subnetCidr')]",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('vmNsgName'))]"
              }
            }
          },
          {
            "name": "[variables('clgClusterSubnetName')]",
            "properties": {
              "addressPrefix": "[parameters('clgClusterSubnetCidr')]",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('clgNsgName'))]"
              },
              "delegations": [
                {
                  "name": "aciDelegation",
                  "properties": {
                    "serviceName": "Microsoft.ContainerInstance/containerGroups"
                  }
                }
              ]
            }
          }
        ]
      }
    },

    {
      "comments": "Static Public IP for the lab VM",
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2023-09-01",
      "name": "[variables('vmPublicIpName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "publicIPAllocationMethod": "Static",
        "publicIPAddressVersion": "IPv4",
        "dnsSettings": {
          "domainNameLabel": "[toLower(concat('labvm-', uniqueString(resourceGroup().id, parameters('DeploymentID'))))]"
        }
      }
    },

    {
      "comments": "NIC for the lab VM",
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2023-09-01",
      "name": "[variables('vmNicName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', variables('virtualNetworkName'))]",
        "[resourceId('Microsoft.Network/publicIPAddresses', variables('vmPublicIpName'))]"
      ],
      "properties": {
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "privateIPAllocationMethod": "Dynamic",
              "subnet": {
                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('virtualNetworkName'), variables('vmSubnetName'))]"
              },
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses', variables('vmPublicIpName'))]"
              }
            }
          }
        ]
      }
    },

    {
      "comments": "Windows Server 2022 VM with Chocolatey, VSCode, Brave, Git, Node.js, n8n, Power Automate, Power BI (mirrors vmInstance UserData)",
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2023-09-01",
      "name": "[variables('vmName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkInterfaces', variables('vmNicName'))]"
      ],
      "properties": {
        "hardwareProfile": {
          "vmSize": "[parameters('vmSize')]"
        },
        "osProfile": {
          "computerName": "[variables('vmName')]",
          "adminUsername": "[parameters('VMUserName')]",
          "adminPassword": "[parameters('VMPassword')]",
          "windowsConfiguration": {
            "provisionVMAgent": true,
            "enableAutomaticUpdates": false
          }
        },
        "storageProfile": {
          "imageReference": {
            "publisher": "MicrosoftWindowsServer",
            "offer": "WindowsServer",
            "sku": "2022-datacenter-azure-edition",
            "version": "latest"
          },
          "osDisk": {
            "name": "[variables('vmOsDiskName')]",
            "createOption": "FromImage",
            "managedDisk": {
              "storageAccountType": "StandardSSD_LRS"
            }
          }
        },
        "networkProfile": {
          "networkInterfaces": [
            {
              "id": "[resourceId('Microsoft.Network/networkInterfaces', variables('vmNicName'))]"
            }
          ]
        }
      }
    },

    {
      "comments": "Custom Script Extension - mirrors EC2 UserData: renames Administrator, installs Chocolatey packages, n8n, Power Automate, Power BI",
      "type": "Microsoft.Compute/virtualMachines/extensions",
      "apiVersion": "2023-09-01",
      "name": "[concat(variables('vmName'), '/CustomScriptExtension')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Compute/virtualMachines', variables('vmName'))]"
      ],
      "properties": {
        "publisher": "Microsoft.Compute",
        "type": "CustomScriptExtension",
        "typeHandlerVersion": "1.10",
        "autoUpgradeMinorVersion": true,
        "settings": {
          "commandToExecute": "[concat('powershell -ExecutionPolicy Unrestricted -Command \"net user Administrator ''', parameters('VMPassword'), '''; Rename-LocalUser -Name Administrator -NewName ', parameters('VMUserName'), '; $Password = ConvertTo-SecureString ''', parameters('VMPassword'), ''' -AsPlainText -Force; $UserAccount = Get-LocalUser -Name ', parameters('VMUserName'), '; $UserAccount | Set-LocalUser -Password $Password; Set-ExecutionPolicy Bypass -Scope Process -Force; [System.Net.ServicePointManager]::SecurityProtocol = [System.Net.ServicePointManager]::SecurityProtocol -bor 3072; Invoke-Expression ((New-Object System.Net.WebClient).DownloadString(''https://community.chocolatey.org/install.ps1'')); if (Test-Path \"$env:ChocolateyInstall\\helpers\\chocolateyProfile.psm1\") { Import-Module \"$env:ChocolateyInstall\\helpers\\chocolateyProfile.psm1\" }; choco install vscode -y --ignore-detected-reboot; choco install brave -y --ignore-detected-reboot; choco install git -y --ignore-detected-reboot; choco install nodejs-lts -y --ignore-detected-reboot; $env:Path += '';C:\\Program Files\\nodejs''; Start-Sleep -Seconds 20; if (Get-Command npm -ErrorAction SilentlyContinue) { try { npm install -g n8n } catch { Start-Sleep -Seconds 20; npm install -g n8n } }; $powerAutomateUrl=''https://go.microsoft.com/fwlink/?linkid=2102613''; $powerAutomateInstaller=\"$env:TEMP\\PowerAutomateSetup.exe\"; Invoke-WebRequest -Uri $powerAutomateUrl -OutFile $powerAutomateInstaller; Start-Process -FilePath $powerAutomateInstaller -ArgumentList ''-Silent'' -Wait; $powerBIUrl=''https://download.microsoft.com/download/8/8/0/880BCA75-79DD-466A-927D-1ABF1F5454B0/PBIDesktopSetup_x64.exe''; $powerBIInstaller=\"$env:TEMP\\PBIDesktopSetup_x64.exe\"; Invoke-WebRequest -Uri $powerBIUrl -OutFile $powerBIInstaller; Start-Process -FilePath $powerBIInstaller -ArgumentList ''-quiet'',''-norestart'' -Wait; Start-Sleep -Seconds 30;\"')]"
        }
      }
    },

    {
      "comments": "Azure Container Instance in the cluster subnet (equivalent to ECS Fargate in clgClusterSubnet with clgSg)",
      "type": "Microsoft.ContainerInstance/containerGroups",
      "apiVersion": "2023-05-01",
      "name": "[variables('containerGroupName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', variables('virtualNetworkName'))]"
      ],
      "properties": {
        "sku": "Standard",
        "subnetIds": [
          {
            "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('virtualNetworkName'), variables('clgClusterSubnetName'))]"
          }
        ],
        "containers": [
          {
            "name": "clg-rdp-container",
            "properties": {
              "image": "mcr.microsoft.com/azure-cli:latest",
              "resources": {
                "requests": {
                  "cpu": 1,
                  "memoryInGB": 2
                }
              },
              "ports": [
                {
                  "protocol": "TCP",
                  "port": 443
                },
                {
                  "protocol": "TCP",
                  "port": 80
                }
              ]
            }
          }
        ],
        "osType": "Linux",
        "restartPolicy": "Always",
        "ipAddress": {
          "type": "Private",
          "ports": [
            {
              "protocol": "TCP",
              "port": 443
            },
            {
              "protocol": "TCP",
              "port": 80
            }
          ]
        }
      }
    }

  ],
  "outputs": {
    "VnetId": {
      "type": "string",
      "description": "The ID of the Virtual Network (equivalent to VpcId)",
      "value": "[resourceId('Microsoft.Network/virtualNetworks', variables('virtualNetworkName'))]"
    },
    "vmSubnetId": {
      "type": "string",
      "description": "The ID of the VM Subnet",
      "value": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('virtualNetworkName'), variables('vmSubnetName'))]"
    },
    "clusterSubnetId": {
      "type": "string",
      "description": "The ID of the Cluster Subnet",
      "value": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('virtualNetworkName'), variables('clgClusterSubnetName'))]"
    },
    "vmSecurityGroupId": {
      "type": "string",
      "description": "The NSG ID of the VM",
      "value": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('vmNsgName'))]"
    },
    "clusterSecurityGroupId": {
      "type": "string",
      "description": "The NSG ID of the Cluster",
      "value": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('clgNsgName'))]"
    },
    "VMName": {
      "type": "string",
      "description": "Name of the VM",
      "value": "[variables('vmName')]"
    },
    "VMPublicIP": {
      "type": "string",
      "description": "VM Public IP Address",
      "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', variables('vmPublicIpName'))).ipAddress]"
    },
    "VMPublicDNSName": {
      "type": "string",
      "description": "VM Public DNS Name (FQDN)",
      "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', variables('vmPublicIpName'))).dnsSettings.fqdn]"
    },
    "VMUserName": {
      "type": "string",
      "description": "VM Username",
      "value": "[parameters('VMUserName')]"
    },
    "VMPassword": {
      "type": "securestring",
      "description": "VM Password",
      "value": "[parameters('VMPassword')]"
    },
    "ContainerGroupName": {
      "type": "string",
      "description": "Name of the Container Group (equivalent to ECS Fargate cluster)",
      "value": "[variables('containerGroupName')]"
    }
  }
}
