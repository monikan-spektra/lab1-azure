{
  "$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "CloudLabsDeploymentID": {
      "type": "string",
      "metadata": { "description": "Will fetch the Deployment ID" }
    },
    "azureUserName": { "type": "string" },
    "azurePassword": { "type": "securestring" },
    "ODLID": { "type": "string" },
    "DeploymentID": { "type": "string" },
    "adminUsername": {
      "type": "string",
      "defaultValue": "azureuser",
      "metadata": { "description": "Accepted for platform compatibility." }
    },
    "adminPassword": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": { "description": "Accepted for platform compatibility." }
    },
    "trainerUserName": {
      "type": "string",
      "defaultValue": "",
      "metadata": { "description": "Accepted for platform compatibility." }
    },
    "trainerUserPassword": {
      "type": "string",
      "defaultValue": "",
      "metadata": { "description": "Accepted for platform compatibility." }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "VPCCIDR": { "type": "string", "defaultValue": "10.0.0.0/16" },
    "EC2InstancesSubnetCIDR": { "type": "string", "defaultValue": "10.0.1.0/24" },
    "clgclusterSubnetCidr": { "type": "string", "defaultValue": "10.0.2.0/24" },
    "cgWhitelist": { "type": "string", "defaultValue": "0.0.0.0/0" },
    "WindowsVMUserName": { "type": "string", "defaultValue": "Labuser" },
    "WindowsVMPassword": { "type": "securestring" },
    "vmSize": { "type": "string", "defaultValue": "Standard_D2s_v3" }
  },
  "variables": {
    "virtualNetworkName": "[concat('EC2InstancesVPC-', parameters('CloudLabsDeploymentID'))]",
    "vmSubnetName": "EC2InstanceSubnet",
    "clgClusterSubnetName": "clgClusterSubnet",
    "vmNsgName": "[concat('EC2InstancesVPCRDP-', parameters('CloudLabsDeploymentID'))]",
    "clgNsgName": "[concat('clgSg-', parameters('CloudLabsDeploymentID'))]",
    "vmPublicIpName": "[concat('labvm-pip-', parameters('CloudLabsDeploymentID'))]",
    "vmNicName": "[concat('labvm-nic-', parameters('CloudLabsDeploymentID'))]",
    "vmName": "[concat('labvm-', parameters('CloudLabsDeploymentID'))]",
    "vmOsDiskName": "[concat('labvm-osdisk-', parameters('CloudLabsDeploymentID'))]",
    "containerGroupName": "[concat('clg-containergroup-', parameters('CloudLabsDeploymentID'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-09-01",
      "name": "[variables('vmNsgName')]",
      "location": "[parameters('location')]",
      "properties": {
        "securityRules": [
          {
            "name": "Allow-RDP-Inbound",
            "properties": {
              "priority": 1000, "direction": "Inbound", "access": "Allow",
              "protocol": "Tcp", "sourcePortRange": "*", "destinationPortRange": "3389",
              "sourceAddressPrefix": "[parameters('cgWhitelist')]", "destinationAddressPrefix": "*"
            }
          },
          {
            "name": "Allow-HTTP-Inbound",
            "properties": {
              "priority": 1100, "direction": "Inbound", "access": "Allow",
              "protocol": "Tcp", "sourcePortRange": "*", "destinationPortRange": "80",
              "sourceAddressPrefix": "[parameters('cgWhitelist')]", "destinationAddressPrefix": "*"
            }
          },
          {
            "name": "Allow-HTTPS-Inbound",
            "properties": {
              "priority": 1200, "direction": "Inbound", "access": "Allow",
              "protocol": "Tcp", "sourcePortRange": "*", "destinationPortRange": "443",
              "sourceAddressPrefix": "[parameters('cgWhitelist')]", "destinationAddressPrefix": "*"
            }
          },
          {
            "name": "Allow-All-ClusterSubnet-Inbound",
            "properties": {
              "priority": 1300, "direction": "Inbound", "access": "Allow",
              "protocol": "Tcp", "sourcePortRange": "*", "destinationPortRange": "*",
              "sourceAddressPrefix": "[parameters('clgclusterSubnetCidr')]", "destinationAddressPrefix": "*"
            }
          },
          {
            "name": "Allow-All-VMSubnet-Inbound",
            "properties": {
              "priority": 1400, "direction": "Inbound", "access": "Allow",
              "protocol": "Tcp", "sourcePortRange": "*", "destinationPortRange": "*",
              "sourceAddressPrefix": "[parameters('EC2InstancesSubnetCIDR')]", "destinationAddressPrefix": "*"
            }
          },
          {
            "name": "Allow-All-Whitelist-Inbound",
            "properties": {
              "priority": 1500, "direction": "Inbound", "access": "Allow",
              "protocol": "*", "sourcePortRange": "*", "destinationPortRange": "*",
              "sourceAddressPrefix": "[parameters('cgWhitelist')]", "destinationAddressPrefix": "*"
            }
          },
          {
            "name": "Allow-All-Outbound",
            "properties": {
              "priority": 100, "direction": "Outbound", "access": "Allow",
              "protocol": "*", "sourcePortRange": "*", "destinationPortRange": "*",
              "sourceAddressPrefix": "*", "destinationAddressPrefix": "*"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2023-09-01",
      "name": "[variables('clgNsgName')]",
      "location": "[parameters('location')]",
      "properties": {
        "securityRules": [
          {
            "name": "Allow-HTTPS-Inbound",
            "properties": {
              "priority": 1000, "direction": "Inbound", "access": "Allow",
              "protocol": "Tcp", "sourcePortRange": "*", "destinationPortRange": "443",
              "sourceAddressPrefix": "0.0.0.0/0", "destinationAddressPrefix": "*"
            }
          },
          {
            "name": "Allow-All-Outbound",
            "properties": {
              "priority": 100, "direction": "Outbound", "access": "Allow",
              "protocol": "*", "sourcePortRange": "*", "destinationPortRange": "*",
              "sourceAddressPrefix": "*", "destinationAddressPrefix": "*"
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2023-09-01",
      "name": "[variables('virtualNetworkName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkSecurityGroups', variables('vmNsgName'))]",
        "[resourceId('Microsoft.Network/networkSecurityGroups', variables('clgNsgName'))]"
      ],
      "properties": {
        "addressSpace": { "addressPrefixes": [ "[parameters('VPCCIDR')]" ] },
        "subnets": [
          {
            "name": "[variables('vmSubnetName')]",
            "properties": {
              "addressPrefix": "[parameters('EC2InstancesSubnetCIDR')]",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('vmNsgName'))]"
              }
            }
          },
          {
            "name": "[variables('clgClusterSubnetName')]",
            "properties": {
              "addressPrefix": "[parameters('clgclusterSubnetCidr')]",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('clgNsgName'))]"
              },
              "delegations": [
                {
                  "name": "aciDelegation",
                  "properties": { "serviceName": "Microsoft.ContainerInstance/containerGroups" }
                }
              ]
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2023-09-01",
      "name": "[variables('vmPublicIpName')]",
      "location": "[parameters('location')]",
      "sku": { "name": "Standard" },
      "properties": {
        "publicIPAllocationMethod": "Static",
        "publicIPAddressVersion": "IPv4",
        "dnsSettings": {
          "domainNameLabel": "[toLower(concat('labvm-', uniqueString(resourceGroup().id, parameters('DeploymentID'))))]"
        }
      }
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2023-09-01",
      "name": "[variables('vmNicName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', variables('virtualNetworkName'))]",
        "[resourceId('Microsoft.Network/publicIPAddresses', variables('vmPublicIpName'))]"
      ],
      "properties": {
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "privateIPAllocationMethod": "Static",
              "privateIPAddress": "10.0.1.10",
              "subnet": {
                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('virtualNetworkName'), variables('vmSubnetName'))]"
              },
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses', variables('vmPublicIpName'))]"
              }
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2023-09-01",
      "name": "[variables('vmName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/networkInterfaces', variables('vmNicName'))]"
      ],
      "properties": {
        "hardwareProfile": { "vmSize": "[parameters('vmSize')]" },
        "osProfile": {
          "computerName": "labvm",
          "adminUsername": "[parameters('WindowsVMUserName')]",
          "adminPassword": "[parameters('WindowsVMPassword')]",
          "windowsConfiguration": {
            "provisionVMAgent": true,
            "enableAutomaticUpdates": false
          }
        },
        "storageProfile": {
          "imageReference": {
            "publisher": "MicrosoftWindowsServer",
            "offer": "WindowsServer",
            "sku": "2022-datacenter-azure-edition",
            "version": "latest"
          },
          "osDisk": {
            "name": "[variables('vmOsDiskName')]",
            "createOption": "FromImage",
            "diskSizeGB": 127,
            "managedDisk": { "storageAccountType": "Premium_LRS" }
          }
        },
        "networkProfile": {
          "networkInterfaces": [
            { "id": "[resourceId('Microsoft.Network/networkInterfaces', variables('vmNicName'))]" }
          ]
        }
      }
    },
    {
      "type": "Microsoft.ContainerInstance/containerGroups",
      "apiVersion": "2023-05-01",
      "name": "[variables('containerGroupName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks', variables('virtualNetworkName'))]"
      ],
      "properties": {
        "sku": "Standard",
        "subnetIds": [
          {
            "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('virtualNetworkName'), variables('clgClusterSubnetName'))]"
          }
        ],
        "containers": [
          {
            "name": "clg-rdp-container",
            "properties": {
              "image": "mcr.microsoft.com/azure-cli:latest",
              "resources": { "requests": { "cpu": 1, "memoryInGB": 2 } },
              "ports": [ { "protocol": "TCP", "port": 443 } ]
            }
          }
        ],
        "osType": "Linux",
        "restartPolicy": "Always",
        "ipAddress": {
          "type": "Private",
          "ports": [ { "protocol": "TCP", "port": 443 } ]
        }
      }
    }
  ],
  "outputs": {
    "VpcId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Network/virtualNetworks', variables('virtualNetworkName'))]"
    },
    "WindowsVMDNSName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', variables('vmPublicIpName'))).dnsSettings.fqdn]"
    },
    "WindowsVMPublicIp": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', variables('vmPublicIpName'))).ipAddress]"
    },
    "WindowsVMPrivateIp": {
      "type": "string",
      "value": "10.0.1.10"
    },
    "WindowsVMUserName": {
      "type": "string",
      "value": "[parameters('WindowsVMUserName')]"
    },
    "WindowsVMPassword": {
      "type": "securestring",
      "value": "[parameters('WindowsVMPassword')]"
    },
    "clusterSubnetId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('virtualNetworkName'), variables('clgClusterSubnetName'))]"
    },
    "clusterSecurityGroupId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('clgNsgName'))]"
    },
    "WindowsVMName": {
      "type": "string",
      "value": "[variables('vmName')]"
    }
  }
}
