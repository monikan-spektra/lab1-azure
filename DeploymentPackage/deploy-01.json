{
    "$schema": "http://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "adminUsername": { "type": "String" },
        "adminPassword": { "type": "SecureString" },
        "AzureUserName": { "type": "String" },
        "AzurePassword": { "type": "SecureString" },
        "ODLID": { "type": "String" },
        "DeploymentID": { "type": "String" },
        "trainerUserName": { "type": "String" },
        "trainerUserPassword": { "type": "String" },
        "pgReplicationPassword": {
            "type": "SecureString",
            "defaultValue": "Repl@PgUser2026!",
            "metadata": { "description": "Password set on the PostgreSQL repl_user role on the primary. Surfaced as a portal output so candidate can use it during pg_basebackup." }
        }
    },
    "variables": {
        "linuxSetupArgs": "[concat(' -azure_user ', parameters('AzureUserName'), ' -azure_password ', parameters('AzurePassword'), ' -odl_id ', parameters('ODLID'), ' -deployment_id ', parameters('DeploymentID'), ' -admin_user ', parameters('adminUsername'), ' -trainer_user ', parameters('trainerUserName'), ' -trainer_password ', parameters('trainerUserPassword'), ' -repl_password ', parameters('pgReplicationPassword'))]",
        "AzureSubscriptionID": "[subscription().subscriptionId]",
        "AzureTenantID": "[subscription().tenantId]",
        "location": "[resourceGroup().location]",
        "primaryVmName": "[concat('pg-primary-', parameters('DeploymentID'))]",
        "replicaVmName": "[concat('pg-replica-', parameters('DeploymentID'))]",
        "primaryNicName": "[concat(variables('primaryVmName'), '-nic')]",
        "replicaNicName": "[concat(variables('replicaVmName'), '-nic')]",
        "primaryPipName": "[concat('pgprimaryip', uniqueString(resourceGroup().id))]",
        "replicaPipName": "[concat('pgreplicaip', uniqueString(resourceGroup().id, 'r'))]",
        "primaryDataDiskName": "[concat(variables('primaryVmName'), '-pgdata')]",
        "replicaDataDiskName": "[concat(variables('replicaVmName'), '-pgdata')]",
        "networkSecurityGroupName": "nsg",
        "virtualNetworkName": "vnet",
        "vnetID": "[resourceId('Microsoft.Network/virtualNetworks', variables('virtualNetworkName'))]",
        "subnetRef": "[concat(variables('vnetID'),'/subnets/','subnet')]",
        "primaryPrivateIp": "10.10.1.4",
        "replicaPrivateIp": "10.10.1.5",
        "setupScriptUrl": "https://microlandlab2.blob.core.windows.net/lab2azure/setup-jumpvm.sh",
        "seedScriptUrl": "https://microlandlab2.blob.core.windows.net/lab2azure/seed-state.sh"
    },
    "resources": [
        {
            "type": "Microsoft.Network/networkSecurityGroups",
            "apiVersion": "2024-05-01",
            "name": "[variables('networkSecurityGroupName')]",
            "location": "[resourceGroup().location]",
            "properties": {
                "securityRules": [
                    { "name": "allow-ssh", "properties": { "priority": 1000, "protocol": "TCP", "access": "Allow", "direction": "Inbound", "sourceAddressPrefix": "*", "sourcePortRange": "*", "destinationAddressPrefix": "*", "destinationPortRange": "22" } },
                    { "name": "allow-postgres-vnet", "properties": { "priority": 1100, "protocol": "TCP", "access": "Allow", "direction": "Inbound", "sourceAddressPrefix": "10.10.0.0/16", "sourcePortRange": "*", "destinationAddressPrefix": "*", "destinationPortRange": "5432" } },
                    { "name": "allow-pgbouncer-vnet", "properties": { "priority": 1110, "protocol": "TCP", "access": "Allow", "direction": "Inbound", "sourceAddressPrefix": "10.10.0.0/16", "sourcePortRange": "*", "destinationAddressPrefix": "*", "destinationPortRange": "6432" } },
                    { "name": "deny-postgres-internet", "properties": { "priority": 4000, "protocol": "TCP", "access": "Deny", "direction": "Inbound", "sourceAddressPrefix": "Internet", "sourcePortRange": "*", "destinationAddressPrefix": "*", "destinationPortRange": "5432" } }
                ]
            }
        },
        {
            "type": "Microsoft.Network/virtualNetworks",
            "apiVersion": "2024-05-01",
            "name": "[variables('virtualNetworkName')]",
            "location": "[resourceGroup().location]",
            "dependsOn": [ "[concat('Microsoft.Network/networkSecurityGroups/', variables('networkSecurityGroupName'))]" ],
            "properties": {
                "addressSpace": { "addressPrefixes": [ "10.10.0.0/16" ] },
                "subnets": [
                    { "name": "subnet", "properties": { "addressPrefix": "10.10.1.0/24", "networkSecurityGroup": { "id": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('networkSecurityGroupName'))]" } } }
                ]
            }
        },
        {
            "type": "Microsoft.Network/publicIPAddresses",
            "apiVersion": "2024-05-01",
            "name": "[variables('primaryPipName')]",
            "location": "[resourceGroup().location]",
            "tags": { "displayName": "PG Primary Public IP" },
            "sku": { "name": "Standard" },
            "properties": { "publicIPAllocationMethod": "Static", "dnsSettings": { "domainNameLabel": "[variables('primaryPipName')]" } }
        },
        {
            "type": "Microsoft.Network/publicIPAddresses",
            "apiVersion": "2024-05-01",
            "name": "[variables('replicaPipName')]",
            "location": "[resourceGroup().location]",
            "tags": { "displayName": "PG Replica Public IP" },
            "sku": { "name": "Standard" },
            "properties": { "publicIPAllocationMethod": "Static", "dnsSettings": { "domainNameLabel": "[variables('replicaPipName')]" } }
        },
        {
            "type": "Microsoft.Network/networkInterfaces",
            "apiVersion": "2024-05-01",
            "name": "[variables('primaryNicName')]",
            "location": "[resourceGroup().location]",
            "dependsOn": [
                "[concat('Microsoft.Network/virtualNetworks/', variables('virtualNetworkName'))]",
                "[concat('Microsoft.Network/publicIpAddresses/', variables('primaryPipName'))]"
            ],
            "properties": {
                "ipConfigurations": [
                    { "name": "ipconfig1", "properties": { "subnet": { "id": "[variables('subnetRef')]" }, "privateIPAllocationMethod": "Static", "privateIPAddress": "[variables('primaryPrivateIp')]", "publicIpAddress": { "id": "[resourceId('Microsoft.Network/publicIPAddresses', variables('primaryPipName'))]" } } }
                ]
            }
        },
        {
            "type": "Microsoft.Network/networkInterfaces",
            "apiVersion": "2024-05-01",
            "name": "[variables('replicaNicName')]",
            "location": "[resourceGroup().location]",
            "dependsOn": [
                "[concat('Microsoft.Network/virtualNetworks/', variables('virtualNetworkName'))]",
                "[concat('Microsoft.Network/publicIpAddresses/', variables('replicaPipName'))]"
            ],
            "properties": {
                "ipConfigurations": [
                    { "name": "ipconfig1", "properties": { "subnet": { "id": "[variables('subnetRef')]" }, "privateIPAllocationMethod": "Static", "privateIPAddress": "[variables('replicaPrivateIp')]", "publicIpAddress": { "id": "[resourceId('Microsoft.Network/publicIPAddresses', variables('replicaPipName'))]" } } }
                ]
            }
        },
        {
            "type": "Microsoft.Compute/disks",
            "apiVersion": "2024-03-02",
            "name": "[variables('primaryDataDiskName')]",
            "location": "[resourceGroup().location]",
            "sku": { "name": "Premium_LRS" },
            "properties": { "creationData": { "createOption": "Empty" }, "diskSizeGB": 256 }
        },
        {
            "type": "Microsoft.Compute/disks",
            "apiVersion": "2024-03-02",
            "name": "[variables('replicaDataDiskName')]",
            "location": "[resourceGroup().location]",
            "sku": { "name": "Premium_LRS" },
            "properties": { "creationData": { "createOption": "Empty" }, "diskSizeGB": 256 }
        },
        {
            "type": "Microsoft.Compute/virtualMachines",
            "apiVersion": "2024-11-01",
            "name": "[variables('primaryVmName')]",
            "location": "[resourceGroup().location]",
            "dependsOn": [
                "[concat('Microsoft.Network/networkInterfaces/', variables('primaryNicName'))]",
                "[concat('Microsoft.Compute/disks/', variables('primaryDataDiskName'))]"
            ],
            "properties": {
                "osProfile": {
                    "computerName": "[variables('primaryVmName')]",
                    "adminUsername": "[parameters('adminUsername')]",
                    "adminPassword": "[parameters('adminPassword')]",
                    "linuxConfiguration": { "disablePasswordAuthentication": false, "provisionVMAgent": true }
                },
                "hardwareProfile": { "vmSize": "Standard_D2s_v3" },
                "storageProfile": {
                    "imageReference": { "publisher": "Canonical", "offer": "0001-com-ubuntu-server-jammy", "sku": "22_04-lts-gen2", "version": "latest" },
                    "osDisk": { "createOption": "fromImage", "managedDisk": { "storageAccountType": "Standard_LRS" } },
                    "dataDisks": [ { "lun": 0, "name": "[variables('primaryDataDiskName')]", "createOption": "Attach", "caching": "ReadWrite", "managedDisk": { "id": "[resourceId('Microsoft.Compute/disks', variables('primaryDataDiskName'))]" } } ]
                },
                "networkProfile": { "networkInterfaces": [ { "id": "[resourceId('Microsoft.Network/networkInterfaces', variables('primaryNicName'))]" } ] }
            },
            "resources": [
                {
                    "type": "extensions",
                    "apiVersion": "2024-11-01",
                    "name": "linuxCustomScript",
                    "location": "[resourceGroup().location]",
                    "dependsOn": [ "[concat('Microsoft.Compute/virtualMachines/', variables('primaryVmName'))]" ],
                    "properties": {
                        "publisher": "Microsoft.Azure.Extensions",
                        "type": "CustomScript",
                        "typeHandlerVersion": "2.1",
                        "autoUpgradeMinorVersion": true,
                        "settings": { "fileUris": [ "[variables('setupScriptUrl')]", "[variables('seedScriptUrl')]" ] },
                        "protectedSettings": { "commandToExecute": "[concat('bash setup-jumpvm.sh -role primary', variables('linuxSetupArgs'))]" }
                    }
                }
            ]
        },
        {
            "type": "Microsoft.Compute/virtualMachines",
            "apiVersion": "2024-11-01",
            "name": "[variables('replicaVmName')]",
            "location": "[resourceGroup().location]",
            "dependsOn": [
                "[concat('Microsoft.Network/networkInterfaces/', variables('replicaNicName'))]",
                "[concat('Microsoft.Compute/disks/', variables('replicaDataDiskName'))]",
                "[concat('Microsoft.Compute/virtualMachines/', variables('primaryVmName'))]"
            ],
            "properties": {
                "osProfile": {
                    "computerName": "[variables('replicaVmName')]",
                    "adminUsername": "[parameters('adminUsername')]",
                    "adminPassword": "[parameters('adminPassword')]",
                    "linuxConfiguration": { "disablePasswordAuthentication": false, "provisionVMAgent": true }
                },
                "hardwareProfile": { "vmSize": "Standard_D2s_v3" },
                "storageProfile": {
                    "imageReference": { "publisher": "Canonical", "offer": "0001-com-ubuntu-server-jammy", "sku": "22_04-lts-gen2", "version": "latest" },
                    "osDisk": { "createOption": "fromImage", "managedDisk": { "storageAccountType": "Standard_LRS" } },
                    "dataDisks": [ { "lun": 0, "name": "[variables('replicaDataDiskName')]", "createOption": "Attach", "caching": "ReadWrite", "managedDisk": { "id": "[resourceId('Microsoft.Compute/disks', variables('replicaDataDiskName'))]" } } ]
                },
                "networkProfile": { "networkInterfaces": [ { "id": "[resourceId('Microsoft.Network/networkInterfaces', variables('replicaNicName'))]" } ] }
            },
            "resources": [
                {
                    "type": "extensions",
                    "apiVersion": "2024-11-01",
                    "name": "linuxCustomScript",
                    "location": "[resourceGroup().location]",
                    "dependsOn": [ "[concat('Microsoft.Compute/virtualMachines/', variables('replicaVmName'))]" ],
                    "properties": {
                        "publisher": "Microsoft.Azure.Extensions",
                        "type": "CustomScript",
                        "typeHandlerVersion": "2.1",
                        "autoUpgradeMinorVersion": true,
                        "settings": { "fileUris": [ "[variables('setupScriptUrl')]", "[variables('seedScriptUrl')]" ] },
                        "protectedSettings": { "commandToExecute": "[concat('bash setup-jumpvm.sh -role replica', variables('linuxSetupArgs'))]" }
                    }
                }
            ]
        }
    ],
    "outputs": {
        "DeploymentID": { "type": "String", "value": "[parameters('DeploymentID')]" },
        "region": { "type": "string", "value": "[variables('location')]" },
        "VM Admin Username": { "type": "String", "value": "[parameters('adminUsername')]" },
        "VM Admin Password": { "type": "String", "value": "[parameters('adminPassword')]" },
        "Primary VM Name": { "type": "String", "value": "[variables('primaryVmName')]" },
        "Replica VM Name": { "type": "String", "value": "[variables('replicaVmName')]" },
        "Primary Public IP": { "type": "String", "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', variables('primaryPipName'))).ipAddress]" },
        "Replica Public IP": { "type": "String", "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', variables('replicaPipName'))).ipAddress]" },
        "Primary VM DNS Name": { "type": "String", "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', variables('primaryPipName'))).dnsSettings.fqdn]" },
        "Replica VM DNS Name": { "type": "String", "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', variables('replicaPipName'))).dnsSettings.fqdn]" },
        "Primary Private IP": { "type": "String", "value": "[variables('primaryPrivateIp')]" },
        "Replica Private IP": { "type": "String", "value": "[variables('replicaPrivateIp')]" },
        "Primary SSH Command": { "type": "String", "value": "[concat('ssh ', parameters('adminUsername'), '@', reference(resourceId('Microsoft.Network/publicIPAddresses', variables('primaryPipName'))).dnsSettings.fqdn)]" },
        "Replica SSH Command": { "type": "String", "value": "[concat('ssh ', parameters('adminUsername'), '@', reference(resourceId('Microsoft.Network/publicIPAddresses', variables('replicaPipName'))).dnsSettings.fqdn)]" },
        "Sample Database": { "type": "String", "value": "mckdb" },
        "PgBench Scale Factor": { "type": "String", "value": "100" },
        "Replication User": { "type": "String", "value": "repl_user" },
        "Replication User Password": { "type": "String", "value": "[parameters('pgReplicationPassword')]" },
        "Trainer Username": { "type": "String", "value": "[parameters('trainerUserName')]" },
        "Trainer Password": { "type": "String", "value": "[parameters('trainerUserPassword')]" }
    }
}
